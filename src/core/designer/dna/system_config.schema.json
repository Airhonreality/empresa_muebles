{
  "id": "system_config_def",
  "name": "Identidad Visual",
  "description": "Tokens de Diseño y Geometría del Sistema",
  "fields": [
    {
      "key": "app_name",
      "label": "Título de la Aplicación",
      "type": "text",
      "required": true
    },
    {
      "key": "primary_color",
      "label": "Color Maestro (Accent)",
      "type": "color",
      "default": "#8b7355"
    },
    {
      "key": "bg_color",
      "label": "Fondo Principal",
      "type": "color",
      "default": "#fafafa"
    },
    {
      "key": "border_radius",
      "label": "Radio de Geometría (px)",
      "type": "number",
      "default": 0
    },
    {
      "key": "font_sans",
      "label": "Tipografía Sans",
      "type": "select",
      "options": [
        { "label": "Inter (Sistema)", "value": "'Inter', sans-serif" },
        { "label": "Roboto", "value": "'Roboto', sans-serif" },
        { "label": "Outfit", "value": "'Outfit', sans-serif" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "key": "font_serif",
      "label": "Tipografía Serif",
      "type": "select",
      "options": [
        { "label": "Playfair Display", "value": "'Playfair Display', serif" },
        { "label": "Lora", "value": "'Lora', serif" }
      ],
      "default": "'Playfair Display', serif"
    }
  ]
}
