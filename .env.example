# ── DATA STRATEGY ────────────────────────────────────────────────────────────
# If GITHUB_TOKEN is set, the app uses GitHubStrategy (cloud persistence).
# If not set, it uses LocalStrategy (reads/writes data-silo/db.json on disk).

# Required for cloud persistence (Vercel deployment):
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_FILE_PATH=db.json
GITHUB_BRANCH=main
