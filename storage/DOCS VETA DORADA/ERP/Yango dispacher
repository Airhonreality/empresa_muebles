## 💻 Implementación del Componente Especializado: `YangoDispatcher`

Este componente React (`src/components/specialized/YangoDispatcher.tsx`) es el encargado de dar vida al flujo ultra-rápido de fletes.

```tsx
'use client'
import React from 'react'
import type { BlockProps } from '@agnostic/core'
import { Button } from '@/components/ui/button'
import { Card, CardContent } from '@/components/ui/card'
import { Play, ClipboardCopy, Check, X } from 'lucide-react'

// Representa los registros hidratados del schema de logistica
interface LogisticaRecord {
  id: string
  data: {
    tipo_viaje: string
    proveedor_transporte: string
    destino_heredado?: string
    costo_flete?: number
    estado_viaje: string
    fecha_viaje: string
  }
}

export default function YangoDispatcher({ records, api }: BlockProps) {
  const viajes = (records as unknown as LogisticaRecord[]).filter(
    v => v.data.estado_viaje === 'Programado'
  )

  const handlePedirViaje = async (viaje: LogisticaRecord) => {
    const direccion = viaje.data.destino_heredado || 'Taller Principal'
    
    try {
      // 1. Copiar dirección al portapapeles del cliente
      await navigator.clipboard.writeText(direccion)
      api.notify.success(`Dirección copiada: "${direccion}"`)
      
      // 2. Abrir aplicación de transporte
      const isUber = viaje.data.proveedor_transporte === 'Uber'
      const appUrl = isUber 
        ? 'https://m.uber.com/looking' 
        : 'https://yango.com/es_cl/' // Enlace Yango o Deep Link 'yango://'
        
      window.open(appUrl, '_blank')
    } catch (err) {
      api.notify.error('Fallo al copiar dirección al portapapeles.')
    }
  }

  return (
    <div className="space-y-4 p-4">
      <h2 className="text-xl font-semibold tracking-tight">Fletes Programados para Hoy</h2>
      {viajes.length === 0 ? (
        <p className="text-sm text-muted-foreground">No hay viajes programados pendientes.</p>
      ) : (
        <div className="grid gap-3">
          {viajes.map((viaje) => (
            <Card key={viaje.id} className="overflow-hidden">
              <CardContent className="flex items-center justify-between p-4">
                <div className="space-y-1">
                  <span className="text-xs font-medium uppercase tracking-wider text-primary">
                    {viaje.data.tipo_viaje.replace(/_/g, ' ')}
                  </span>
                  <p className="text-sm font-semibold">{viaje.data.destino_heredado}</p>
                  <p className="text-xs text-muted-foreground">
                    Proveedor: {viaje.data.proveedor_transporte}
                  </p>
                </div>
                
                <div className="flex items-center gap-2">
                  <Button 
                    size="sm" 
                    variant="default"
                    onClick={() => handlePedirViaje(viaje)}
                    className="flex items-center gap-1.5"
                  >
                    <Play className="h-3.5 w-3.5 fill-current" />
                    Pedir {viaje.data.proveedor_transporte}
                  </Button>
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      )}
    </div>
  )
}
```

